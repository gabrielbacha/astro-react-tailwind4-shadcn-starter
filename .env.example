# Copy to `.env` for local overrides. All values are optional — defaults come
# from `src/config/site.ts`. These are public build-time values (the site is
# fully static), so never put secrets here.
#
# On GitHub Pages, set these as repository Actions variables (Settings →
# Secrets and variables → Actions → Variables); the deploy workflow passes
# them to the build.

# Full production URL of the site, e.g. https://your-username.github.io
PUBLIC_SITE_URL=

# Base path the site is served from. For a GitHub Pages project site this is
# the repo name with slashes, e.g. /your-repo/. Leave empty for "/".
PUBLIC_BASE=

# Google Tag Manager container ID, e.g. GTM-XXXXXXX. Empty disables GTM.
PUBLIC_GTM_ID=

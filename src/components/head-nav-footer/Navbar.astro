---
import ThemeToggle from "@/components/utilities/ThemeToggle.astro";
import { siteConfig } from "@/config/site";
import { getAssetPath } from "@/lib/utils";
---

<header class="border-border/70 bg-background/85 supports-[backdrop-filter]:bg-background/70 border-b backdrop-blur-md">
	<nav aria-label="Primary navigation" class="mx-auto grid h-20 w-full max-w-7xl grid-cols-[1fr_auto_1fr] items-center px-4 sm:px-6 lg:px-8">
		<span aria-hidden="true"></span>
		<a
			href={getAssetPath("")}
			class="text-foreground focus-visible:ring-ring min-w-0 rounded-sm text-center text-2xl font-bold tracking-tight transition-colors hover:text-primary/75 focus-visible:ring-2 focus-visible:ring-offset-4 focus-visible:outline-none sm:text-3xl"
		>
			<span class="block max-w-[60vw] truncate">{siteConfig.name}</span>
		</a>
		<div class="justify-self-end">
			<ThemeToggle />
		</div>
	</nav>
</header>

---
import { buttonVariants } from "@/components/ui/button";
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { getAssetPath } from "@/lib/utils";
import type { SeoData } from "@/types/seo";

const title = `${siteConfig.name} | Coming Soon`;
const description = "A modern, minimal coming-soon landing page. Swap this copy, the wordmark, and the buttons to make it yours.";
const siteUrl = Astro.site ?? Astro.url;
const sameAs = Object.values(siteConfig.socialMedia).filter((url): url is string => Boolean(url));

// Brand icons are no longer shipped by lucide, so the paths live here (24x24, stroke-based).
const socialIconPaths = {
	instagram:
		"M16 3H8a5 5 0 0 0-5 5v8a5 5 0 0 0 5 5h8a5 5 0 0 0 5-5V8a5 5 0 0 0-5-5Z M12 15.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7Z M16.75 7.25h.01",
	twitter: "M4 4l7.09 9.83L4.24 20h2.6l5.42-4.9L15.8 20H20l-7.35-10.18L19.06 4h-2.6l-4.98 4.5L8.2 4H4Z",
} as const;

const socialLinks = [
	{ label: "Instagram", href: siteConfig.socialMedia.instagram, iconPath: socialIconPaths.instagram },
	{ label: "Twitter", href: siteConfig.socialMedia.twitter, iconPath: socialIconPaths.twitter },
].filter((link): link is typeof link & { href: string } => Boolean(link.href));

const seo = {
	title,
	description,
	image: getAssetPath("og-image.png"),
	imageAlt: `${siteConfig.name} social preview`,
	structuredData: {
		"@context": "https://schema.org",
		"@type": "Organization",
		name: siteConfig.name,
		description,
		url: new URL(Astro.url.pathname, siteUrl).href,
		logo: new URL(getAssetPath("android-chrome-512x512.png"), siteUrl).href,
		...(sameAs.length > 0 ? { sameAs } : {}),
	},
} satisfies SeoData;
---

<Layout seo={seo}>
	<section class="relative isolate flex h-full min-h-[36rem] flex-col items-center justify-center overflow-hidden px-4 py-16 text-center sm:px-6">
		<!-- Faint grid backdrop, faded out toward the edges -->
		<div
			aria-hidden="true"
			class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,var(--border)_1px,transparent_1px),linear-gradient(to_bottom,var(--border)_1px,transparent_1px)] bg-[size:3.5rem_3.5rem] [mask-image:radial-gradient(ellipse_70%_60%_at_50%_45%,black_35%,transparent_100%)]"
		>
		</div>
		<!-- Soft radial glow behind the heading -->
		<div
			aria-hidden="true"
			class="bg-primary/10 absolute top-1/2 left-1/2 -z-10 h-[28rem] w-[44rem] max-w-[90vw] -translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
		>
		</div>

		<p class="border-border bg-background/60 text-muted-foreground animate-fade-up mb-6 inline-flex items-center gap-2 rounded-full border px-4 py-1.5 text-sm tracking-wide backdrop-blur">
			<span class="relative flex size-2">
				<span class="bg-primary absolute inline-flex h-full w-full animate-ping rounded-full opacity-60"></span>
				<span class="bg-primary relative inline-flex size-2 rounded-full"></span>
			</span>
			Coming soon
		</p>
		<h1 class="animate-fade-up mb-6 bg-gradient-to-b from-[var(--foreground)] to-[var(--muted-foreground)] bg-clip-text text-5xl font-bold text-balance text-transparent [animation-delay:100ms] md:text-7xl">
			{siteConfig.name}
		</h1>
		<p class="text-muted-foreground animate-fade-up mx-auto mb-10 max-w-xl text-lg text-pretty [animation-delay:200ms]">
			A clean, minimal starter you can make your own. Replace this copy with whatever you're building.
		</p>
		<div class="animate-fade-up flex flex-col gap-4 [animation-delay:300ms] sm:flex-row">
			<a href="https://docs.astro.build" target="_blank" rel="noopener noreferrer" class={buttonVariants({ size: "lg" })}>
				Get Started
			</a>
			<a href="https://github.com/withastro/astro" target="_blank" rel="noopener noreferrer" class={buttonVariants({ variant: "outline", size: "lg" })}>
				Learn More
			</a>
		</div>
		{
			socialLinks.length > 0 && (
				<div class="animate-fade-up mt-10 flex items-center gap-2 [animation-delay:400ms]">
					{socialLinks.map(({ label, href, iconPath }) => (
						<a
							href={href}
							target="_blank"
							rel="noopener noreferrer"
							aria-label={label}
							class={buttonVariants({ variant: "ghost", size: "icon" })}
						>
							<svg
								class="size-5"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<path d={iconPath} />
							</svg>
						</a>
					))}
				</div>
			)
		}
	</section>
</Layout>

---
import Layout from "@/layouts/Layout.astro";
---

<Layout>
	<div class="bg-background flex min-h-screen flex-col items-center justify-center">
		<section class="flex min-h-full flex-1 flex-col items-center justify-center py-8">
			<div class="max-w-md text-center">
				<h1 class="mb-4 text-3xl font-medium">404: Page not found</h1>
				<p>Oops! The page you're looking for doesn't exist.</p>
			</div>
			<a href="/" class="text-muted-foreground mt-4">Go to home page</a>
		</section>
	</div>
</Layout>

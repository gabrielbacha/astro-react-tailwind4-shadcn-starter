---
import { siteConfig } from "@/config/site";
import Layout from "@/layouts/Layout.astro";
import { getAssetPath } from "@/lib/utils";

const seo = {
	title: `Page Not Found | ${siteConfig.name}`,
	description: "The page you requested could not be found.",
	noindex: true,
};
---

<Layout seo={seo}>
	<section class="flex h-full min-h-[28rem] flex-col items-center justify-center px-4 py-16 text-center">
		<p class="text-muted-foreground mb-3 text-sm tracking-wide uppercase">Error 404</p>
		<h1 class="mb-4 text-3xl font-medium text-balance">Page Not Found</h1>
		<p class="text-muted-foreground max-w-md text-pretty">The page you're looking for doesn't exist or may have moved.</p>
		<a
			href={getAssetPath("")}
			class="text-foreground focus-visible:ring-ring mt-6 rounded-sm underline decoration-current/40 underline-offset-4 transition-colors hover:decoration-current focus-visible:ring-2 focus-visible:ring-offset-4 focus-visible:outline-none"
		>
			Go to Home Page
		</a>
	</section>
</Layout>

{
	"editor.formatOnSave": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.oxc": "explicit"
	},
	"oxc.enable": true,
	"oxc.lint.run": "onType",
	"typescript.tsdk": "node_modules/typescript/lib",
	"typescript.enablePromptUseWorkspaceTsdk": true,
	"files.exclude": {
		"**/node_modules": true,
		"**/.astro": true,
		"**/dist": true,
		"**/out": true,
		"**/build": true,
		"**/coverage": true,
		"**/*.tsbuildinfo": true,
		"**/pnpm-lock.yaml": true,
		"**/.DS_Store": true,
		"**/Thumbs.db": true
	}
}
